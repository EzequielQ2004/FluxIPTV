{
  "manifest_version": 3,
  "name": "Flux IPTV",
  "version": "1.0",
  "description": "Guarda y abre tus listas M3U en Flux IPTV",
  "permissions": [
    "storage",
    "contextMenus",
    "clipboardRead"
  ],
  "host_permissions": [
    "https://fluxiptv.qzz.io/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Flux IPTV",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
